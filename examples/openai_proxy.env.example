# PostgreSQL and local embeddings
DREAMCYCLE_POSTGRES_DSN=postgresql://dreamcycle:replace-me@127.0.0.1/dreamcycle
DREAMCYCLE_EMBEDDING_MODEL=/absolute/path/to/local/embedding-model

# The vendor application uses this key when calling the DreamCycle sidecar.
DREAMCYCLE_API_KEY=replace-with-a-random-sidecar-key
DREAMCYCLE_NAMESPACE=vendor-product
DREAMCYCLE_USER_ID=local-user

# Existing local OpenAI-compatible model server.
DREAMCYCLE_UPSTREAM_BASE_URL=http://127.0.0.1:11434/v1
# DREAMCYCLE_UPSTREAM_API_KEY=separate-upstream-key
DREAMCYCLE_PROXY_MODE=observe

# Optional local training. Configure both or neither.
# DREAMCYCLE_BASE_MODEL=/absolute/path/to/local-hugging-face-model
# DREAMCYCLE_DATA_DIR=/absolute/path/to/dreamcycle-data
